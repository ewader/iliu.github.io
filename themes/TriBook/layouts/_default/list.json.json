{{- $pages := where site.RegularPages "Kind" "page" -}}
{{- $pages = where $pages "Params.draft" "!=" true -}}
{
  "title": "{{ site.Title }}",
  "baseURL": "{{ site.BaseURL }}",
  "language": "{{ site.Language.Lang }}",
  "pages": [
    {{- range $index, $page := $pages -}}
    {{- if gt $index 0 }},{{ end }}
    {
      "title": {{ $page.Title | jsonify }},
      "url": "{{ $page.RelPermalink }}",
      "date": "{{ $page.Date.Format "2006-01-02" }}",
      "summary": {{ $page.Summary | jsonify }},
      "content": {{ $page.Plain | jsonify }},
      "tags": {{ with $page.Params.tags }}{{ . | jsonify }}{{ else }}[]{{ end }},
      "categories": {{ with $page.Params.categories }}{{ . | jsonify }}{{ else }}[]{{ end }}
    }
    {{- end -}}
  ]
}